# Polymarket Gamma Starter v1.9.0-real configuration

# Bind to all interfaces so other devices on your LAN can access the app.
# Use HOST=127.0.0.1 to make it local-only again.
HOST=127.0.0.1
PORT=8000
APP_RELOAD=true

# LAN/security controls. Use * for easy LAN testing, or set fixed hosts/IPs.
ALLOWED_HOSTS=127.0.0.1,localhost
SECURITY_HEADERS_ENABLED=true
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax

GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_BASE_URL=https://clob.polymarket.com
REQUEST_TIMEOUT_SECONDS=20
DEFAULT_LIMIT=20

APP_MODE=read_only
READ_ONLY=true
LIVE_TRADING_ENABLED=false

PAPER_MAX_STAKE_PER_TRADE=250
PAPER_MAX_MARKET_EXPOSURE=500
PAPER_MAX_TOTAL_EXPOSURE=2500
PAPER_MAX_OPEN_POSITIONS=20
PAPER_MIN_LIQUIDITY=1000
PAPER_MIN_VOLUME_24HR=10
PAPER_BLOCK_EXTREME_PRICES=true
PAPER_MIN_PRICE=0.02
PAPER_MAX_PRICE=0.98

# Future optional integrations. Not needed for the current local paper workflow.
OPENAI_API_KEY=
NEWS_API_KEY=

# v0.9.0 staged live-readiness gates. Values are redacted in reports and used only by local readiness/adapter previews.
# This build does not derive credentials, sign messages, place orders, cancel orders,
# or automate live trading.
LIVE_DRY_RUN_ONLY=true
LIVE_REQUIRE_MANUAL_APPROVAL=true
LIVE_PRETRADE_CHECKS_ENABLED=true
LIVE_AUDIT_REQUIRED=true
LIVE_MAX_ORDER_NOTIONAL=0
LIVE_MAX_MARKET_NOTIONAL=0
LIVE_MAX_DAILY_NOTIONAL=0
LIVE_MAX_OPEN_ORDERS=0
LIVE_ALLOWED_MARKET_IDS=

# Live adapter boundary. All execution-facing controls are default-off.
POLYMARKET_LIVE_MODE=false
POLYMARKET_LIVE_NETWORK_READONLY=false
POLYMARKET_LIVE_ENABLE_SUBMIT=false
POLYMARKET_LIVE_ENABLE_CANCEL=false
POLYMARKET_LIVE_REQUIRE_MANUAL_AUTH=true
POLYMARKET_LIVE_KILL_SWITCH=true
POLYMARKET_LIVE_REQUIRE_DRY_RUN_RECEIPT=true
POLYMARKET_LIVE_READONLY_TIMEOUT_SECONDS=4
POLYMARKET_CLOB_HOST=https://clob.polymarket.com

# v0.9.0 manual live execution control plane. These are all default-off.
# Fake receipts are local simulations only. Real live submit/cancel are implemented behind hard gates.
POLYMARKET_LIVE_MANUAL_SUBMIT_ENABLED=false
POLYMARKET_LIVE_MANUAL_CANCEL_ENABLED=false
POLYMARKET_LIVE_FAKE_ADAPTER_ENABLED=false
POLYMARKET_LIVE_REAL_ADAPTER_EXPERIMENTAL=false
POLYMARKET_RUN_REAL_LIVE_TESTS=false
POLYMARKET_REAL_LIVE_TEST_CONFIRMATION=
POLYMARKET_LIVE_FINAL_CONFIRMATION_PHRASE=
POLYMARKET_LIVE_AUTHORIZATION_MAX_AGE_MINUTES=60
POLYMARKET_LIVE_DRY_RUN_MAX_AGE_MINUTES=60
POLYMARKET_LIVE_ADAPTER_REQUEST_MAX_AGE_MINUTES=60

# v0.9.0 market-data intelligence and execution-quality simulator.
# Public fetch remains disabled by default; local/manual JSON fixtures are supported without network.
POLYMARKET_MARKET_DATA_REQUIRE_FOR_LIVE=true
POLYMARKET_MARKET_DATA_MAX_AGE_SECONDS=300
POLYMARKET_MARKET_DATA_MAX_SPREAD_BPS=250
POLYMARKET_MARKET_DATA_MAX_SLIPPAGE_BPS=150
POLYMARKET_MARKET_DATA_MIN_TOP_DEPTH=10
POLYMARKET_MARKET_DATA_MIN_TOTAL_DEPTH=50
POLYMARKET_MARKET_DATA_PUBLIC_FETCH_ENABLED=false
POLYMARKET_MARKET_DATA_TIMEOUT_SECONDS=4


# v1.1.0 CLOB adapter boundary reminder:
# Real submit/cancel remain fail-closed unless every manual live gate passes; normal validation does not submit/cancel.
POLYMARKET_LIVE_ALLOW_REAL_NETWORK=false

# Future Polymarket/CLOB identity and credential fields.
# Populate only in your local .env, never in a shared ZIP.
POLYMARKET_CHAIN_ID=137
POLYMARKET_SIGNATURE_TYPE=
POLYMARKET_FUNDER_ADDRESS=
POLY_ADDRESS=
POLYMARKET_WALLET_ADDRESS=
POLY_PRIVATE_KEY=
POLYMARKET_PRIVATE_KEY=
POLY_API_KEY=
POLYMARKET_CLOB_API_KEY=
CLOB_API_KEY=
POLY_SECRET=
POLYMARKET_CLOB_SECRET=
CLOB_SECRET=
POLY_PASSPHRASE=
POLYMARKET_CLOB_PASSPHRASE=
CLOB_PASSPHRASE=

# Deployment/admin diagnostics
# Visit /administration/config after login as admin.

# Research source availability checks
SOURCE_CHECK_TIMEOUT=4

# v1.1.0 guarded live/autonomous controls (safe defaults; duplicated names are kept for backward compatibility)
POLYMARKET_LIVE_MODE=false
POLYMARKET_LIVE_NETWORK_READONLY=false
POLYMARKET_LIVE_ENABLE_SUBMIT=false
POLYMARKET_LIVE_ENABLE_CANCEL=false
POLYMARKET_LIVE_ENABLE_AUTONOMOUS=false
POLYMARKET_LIVE_REQUIRE_MANUAL_AUTH=true
POLYMARKET_LIVE_KILL_SWITCH=true
POLYMARKET_LIVE_ALLOW_REAL_NETWORK=false
POLYMARKET_LIVE_MAX_ORDER_NOTIONAL=0
POLYMARKET_LIVE_MAX_DAILY_NOTIONAL=0
POLYMARKET_LIVE_MAX_OPEN_ORDERS=0
POLYMARKET_LIVE_MAX_POSITION_NOTIONAL=0
POLYMARKET_LIVE_MAX_DAILY_LOSS=0
POLYMARKET_LIVE_MARKET_ALLOWLIST=
POLYMARKET_LIVE_TOKEN_ALLOWLIST=
POLYMARKET_LIVE_FINAL_CONFIRMATION_PHRASE=
POLYMARKET_LIVE_EMERGENCY_CANCEL_ENABLED=false
POLYMARKET_LIVE_FAKE_ADAPTER_ENABLED=false
POLYMARKET_AUTONOMOUS_MAX_ORDERS_PER_RUN=0
POLYMARKET_AUTONOMOUS_MAX_ORDERS_PER_DAY=0
POLYMARKET_AUTONOMOUS_MIN_SIGNAL_CONFIDENCE=
POLYMARKET_AUTONOMOUS_REQUIRE_MARKET_DATA=true
POLYMARKET_AUTONOMOUS_REQUIRE_EXECUTION_QUALITY=true
POLYMARKET_AUTONOMOUS_REQUIRE_PAPER_APPROVAL=true
POLYMARKET_AUTONOMOUS_STRATEGY_ALLOWLIST=
POLYMARKET_AUTONOMOUS_DRY_RUN_BY_DEFAULT=true
POLYMARKET_AUTONOMOUS_SCHEDULER_ENABLED=false
POLYMARKET_AUTONOMOUS_SCHEDULER_INTERVAL_SECONDS=0
POLYMARKET_AUTONOMOUS_SCHEDULER_DRY_RUN_ONLY=true

# v1.1.0 SDK mapping and verification controls (safe defaults; no real values)
POLYMARKET_LIVE_SDK_FAMILY=current_py_clob_client
POLYMARKET_LIVE_SDK_SUBMIT_METHOD=create_order+post_order
POLYMARKET_LIVE_SDK_CANCEL_METHOD=cancel
# Optional dependency is documented in requirements-live-optional.txt; core app still runs without it.

# v1.1.0 optional verification confirmations (safe default blank)
POLYMARKET_LIVE_READONLY_REQUEST_CONFIRMATION=
POLYMARKET_LIVE_SUBMIT_SMOKE_CONFIRMATION=
POLYMARKET_LIVE_CANCEL_SMOKE_CONFIRMATION=

# Training & Evaluation Lab (v1.2.0)
# Training data/artifacts are local runtime state under data/training and are excluded from release ZIPs.
TRAINING_LAB_ENABLED=true
TRAINING_DEFAULT_MODEL_TYPE=heuristic_baseline
TRAINING_OUTPUTS_MANUAL_REVIEW_ONLY=true
TRAINING_ALLOW_LIVE_EXECUTION=false

# v1.3.0 Data Ingestion + Dataset Builder - safe defaults
POLYMARKET_DATA_ALLOW_NETWORK=false
POLYMARKET_DATA_INGESTION_SCHEDULER_ENABLED=false
POLYMARKET_DATA_INGESTION_MAX_ROWS=100000
POLYMARKET_DATA_DEFAULT_SPLIT_METHOD=chronological

# v1.7.0 Internet ingestion + scoped backfill + dataset-backed host training safe defaults
POLYMARKET_DATA_ALLOW_INTERNET=false
POLYMARKET_DATA_INGESTION_SCHEDULER_ENABLED=false
POLYMARKET_DATA_ALLOWED_DOMAINS=
POLYMARKET_DATA_MAX_REQUESTS_PER_RUN=25
POLYMARKET_DATA_REQUEST_TIMEOUT_SECONDS=10
POLYMARKET_DATA_RATE_LIMIT_SECONDS=1
POLYMARKET_DATA_USER_AGENT=PolymarketGammaStarterLocalResearch/1.0
POLYMARKET_DATA_STORE_RAW_RESPONSES=false
POLYMARKET_DATA_MAX_RAW_RESPONSE_BYTES=1000000
POLYMARKET_DATA_REQUIRE_OPERATOR_CONFIRMATION=true
POLYMARKET_TRAINING_HOST_JOBS_ENABLED=false
POLYMARKET_TRAINING_MAX_RUNTIME_SECONDS=900
POLYMARKET_TRAINING_MAX_ROWS=100000
POLYMARKET_TRAINING_MAX_ARTIFACT_BYTES=50000000
POLYMARKET_TRAINING_ALLOWED_JOB_TYPES=baseline_training,threshold_training,momentum_training,walk_forward_backtest,dataset_quality_scan,feature_build,signal_generation_preview

POLYMARKET_DATA_MAX_BACKFILL_RECORDS=500000
POLYMARKET_DATA_MAX_BACKFILL_REQUESTS=500
POLYMARKET_DATA_BACKFILL_BATCH_SIZE=1000
POLYMARKET_DATA_MAX_STORAGE_MB_PER_JOB=5000
POLYMARKET_DATA_BLOCK_LARGE_BACKFILLS_BY_DEFAULT=true

# v1.7.0 100K local host-training caps. Host jobs remain disabled until explicitly enabled.
POLYMARKET_TRAINING_DEFAULT_MAX_ROWS=100000
POLYMARKET_TRAINING_HARD_MAX_ROWS=1000000
POLYMARKET_TRAINING_BATCH_SIZE=5000
POLYMARKET_TRAINING_BLOCK_OVER_HARD_MAX_ROWS=true
